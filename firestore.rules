rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: barter_items
    // Document ID: auto-generated
    // Fields:
    //   - title: string (1-100 chars)
    //   - description: string (1-2000 chars)
    //   - category: string
    //   - images: list of strings (1-3 items)
    //   - estimatedValue: number
    //   - city: string
    //   - pincode: string (optional)
    //   - userId: string (matches creator UID)
    //   - userName: string
    //   - userEmail: string
    //   - createdAt: string (ISO 8601)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - role: string ('admin' | 'user')
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "akshatsinghp2007@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidBarterItem(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'images', 'estimatedValue', 'city', 'userId', 'userName', 'userEmail', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             data.category is string &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 3 &&
             data.estimatedValue is number &&
             data.city is string &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    // Rules for barter_items
    match /barter_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBarterItem(request.resource.data);
      allow update: if isAuthenticated() && 
                      (resource.data.userId == request.auth.uid || isAdmin()) && 
                      isValidBarterItem(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Rules for users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Rule for test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
